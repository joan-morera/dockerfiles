# Stage 1: Build
FROM node:22-alpine AS builder

WORKDIR /app

# Arguments for version tracking
ARG SHATARI_FRONT_VERSION=master

RUN apk add --no-cache git

# Clone and build
RUN git clone https://github.com/erorus/shatari-front.git . && \
    git checkout ${SHATARI_FRONT_VERSION} && \
    npm install && \
    npm run build

# Stage 2: Production
FROM nginx:alpine

# Copy built files
COPY --from=builder /app/dist /usr/share/nginx/html

# Create directories for mounting backend data
RUN mkdir -p /usr/share/nginx/html/data /usr/share/nginx/html/json

# Custom nginx config to ensure SPA routing if needed (though Shatari seems to be a single index.html)
# and to handle the /data and /json mounts correctly.
COPY <<EOF /etc/nginx/conf.d/default.conf
server {
    listen 80;
    server_name localhost;

    location / {
        root /usr/share/nginx/html;
        index index.html;
        try_files \$uri \$uri/ /index.html;
    }

    # Serve auction data generated by backend
    location /data/ {
        alias /usr/share/nginx/html/data/;
        autoindex on;
    }

    # Serve realm data generated by backend
    location /json/ {
        alias /usr/share/nginx/html/json/;
        autoindex on;
    }

    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
        root /usr/share/nginx/html;
    }
}
EOF

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]

